{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Next.js Web (oddsmera-web)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000,
      "cwd": "web"
